{
  "name": "watchverse-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w @watchverse/frontend",
    "dev:backend": "npm run start:dev -w @watchverse/backend",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present"
  },
  "dependencies": {
    "zustand": "^5.0.13"
  }
}
