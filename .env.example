# =========================================================================
# WatchVerse Master Environment Variables Template
# =========================================================================
# Rename this file to .env in your root directory and customize the values.
# NEVER commit the actual .env file with production credentials to source control.

# 1. TURN Server & WebRTC Relay Configurations
# ---------------------------------------------
# Shared secret for HMAC-SHA1 signature calculations. Must match both the backend and coturn container.
TURN_SECRET=supersecretturnkeychangeinproduction

# Authentication domain/realm for the TURN server.
TURN_REALM=turn.watchverse.com

# External host/IP address of the TURN server. Use your public server IP in production.
# For local testing, 'localhost' or '127.0.0.1' is sufficient.
TURN_HOST=localhost

# Port of the TURN server (default is 3478, TLS default is 5349).
TURN_PORT=3478

# 2. Backend & API Services
# -------------------------
# Local and production ports for NestJS application
PORT=3001

# Public URL of the backend REST API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public WebSocket URL of the signaling Socket.IO server
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# 3. Database & Caching Services
# ------------------------------
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/watchverse

# Redis connection string for socket horizontal scaling adapters
REDIS_URL=redis://localhost:6379

# 4. Authentication Secrets
# -------------------------
# Secret key used to sign and verify JSON Web Tokens (JWT)
JWT_SECRET=supersecretchangeinproduction
